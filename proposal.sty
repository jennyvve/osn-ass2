\newcommand*{\groupname}{Group 4}
%% \SetTitleAndGroup{<Title>}{<Group>}{<Authors>}
\NewDocumentCommand{\SetTitleAndGroup}{m m m}{
  \title{\textsc{#1}}
  \author{#2: #3}
  \renewcommand*{\groupname}{#2}
  \hypersetup{
    pdfauthor={#2 (#3)},
    pdftitle={RMCS 2026 Proposal: #1}
  }
}

