% Typesetting objectives and deliverables
\NewDocumentCommand{\Ob}{m}{\textbf{O#1}}
\NewDocumentCommand{\D}{m m}{\textbf{D#1.#2}}

%% Colours used in the Gantt-chart
\colorlet{firstcolour}{red!50}
\colorlet{secondcolour}{green!50}
\colorlet{thirdcolour}{yellow!50}
\colorlet{fourthcolour}{pink!50}

% Creating Gantt chart
% \begin{ganttproposal}{<No. of years>}{<Subdivision of years (e.g., 4 four quarters)>}
\NewDocumentEnvironment{ganttproposal}{m m}{
  % Save arguments for internal use
  \newcounter{ganttproposalyears}
  \newcounter{ganttproposalparts}
  \setcounter{ganttproposalyears}{#1}
  \setcounter{ganttproposalparts}{#2}
  %% Calculate size
  \pgfmathparse{int(\value{ganttproposalyears} * \value{ganttproposalparts})}
  \begin{ganttchart}{1}{\pgfmathresult}
    \ganttset{
      vgrid
      , x unit=5mm
      , y unit title=5mm
      , y unit chart=5mm
      , bar height = .3
      , bar top shift = .2
      , bar label font = {\small}
      , group top shift = .2
      , group/.append style={draw=black}
      , group label font = {\bfseries\small}
      , bar label text={\hspace*{5pt} \strut##1}
      , group label text={\strut##1}
      , milestone label text={\hspace*{5pt} \strut##1}
      , bar label node/.append style={text width=7cm}
      , group label node/.append style={text width=7cm}
      , milestone label node/.append style={text width=7cm}
    }
}{
  \end{ganttchart}
}

%% Can be used inside ganttproposal to typeset the header.
\NewDocumentCommand{\ganttproposalheader}{}{
  % List years
  \gantttitlelist[
  title list options=%
  {var=\y, evaluate=\y as \x using "Year \y"}%
  ]{1,...,\value{ganttproposalyears}}{\value{ganttproposalparts}} \\
  % List subdivisions
  \pgfmathparse{int((\value{ganttproposalyears} * \value{ganttproposalparts}) - 1)}
  \gantttitlelist[
  title list options=%
  {var=\y, evaluate=\y as \x using {int(mod(\y,\value{ganttproposalparts}) + 1)}}%
  ]{0,...,\pgfmathresult}{1} \\
}